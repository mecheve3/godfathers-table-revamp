# Cloudflare Worker URL for multiplayer room management
# Development: start the worker locally with `cd worker && npm run dev`
# Production:  your deployed worker URL (e.g. https://godfathers-table-room.<account>.workers.dev)
VITE_WORKER_URL=http://localhost:8787

# Analytics & monitoring (leave blank or set VITE_ANALYTICS_ENABLED=false to disable locally)
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx
VITE_ANALYTICS_ENABLED=true
VITE_CF_ANALYTICS_TOKEN=xxx
VITE_APP_VERSION=1.0.0
