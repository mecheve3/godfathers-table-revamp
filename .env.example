# Cloudflare Worker URL for multiplayer room management
# Development: start the worker locally with `cd worker && npm run dev`
# Production:  your deployed worker URL (e.g. https://godfathers-table-room.<account>.workers.dev)
VITE_WORKER_URL=http://localhost:8787

# Analytics & monitoring
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx
VITE_CF_ANALYTICS_TOKEN=xxx
# Set by CI (git rev-parse --short HEAD) — tag every Sentry event with the exact commit
VITE_RELEASE=local-dev

# Sentry source-map upload (build-time only, never exposed to the browser)
# Get from: Sentry → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=sntrys_xxx
# Your Sentry org and project slugs (visible in the Sentry URL)
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
